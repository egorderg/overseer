{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://overseer.app/schemas/config.json",
	"title": "Overseer Configuration",
	"description": "Configuration file for Overseer IDE workspace",
	"type": "object",
	"required": ["projects"],
	"properties": {
		"font": {
			"$ref": "#/$defs/fontSettings",
			"description": "Global font settings for code editors and terminals"
		},
		"terminal": {
			"$ref": "#/$defs/terminalSettings",
			"description": "Global terminal settings and shell defaults"
		},
		"projects": {
			"type": "array",
			"description": "List of projects in the workspace",
			"items": {
				"$ref": "#/$defs/project"
			}
		}
	},
	"$defs": {
		"project": {
			"type": "object",
			"required": ["path", "name"],
			"properties": {
				"path": {
					"type": "string",
					"description": "Absolute path to the project directory",
					"examples": ["/home/user/projects/my-app"]
				},
				"name": {
					"type": "string",
					"description": "Display name for the project",
					"examples": ["my-app"]
				},
				"explorers": {
					"type": "array",
					"description": "Explorer views for this project",
					"items": {
						"$ref": "#/$defs/explorer"
					}
				},
				"diff": {
					"$ref": "#/$defs/viewConfig",
					"description": "Diff view configuration"
				},
				"terminals": {
					"type": "array",
					"description": "Terminal views for this project",
					"items": {
						"$ref": "#/$defs/terminal"
					}
				},
				"collapsed": {
					"type": "boolean",
					"description": "Whether the project is collapsed in the sidebar",
					"default": false
				}
			},
			"additionalProperties": false
		},
		"viewConfig": {
			"type": "object",
			"properties": {
				"enabled": {
					"type": "boolean",
					"description": "Whether this view is shown for the project",
					"default": true
				}
			},
			"additionalProperties": false
		},
		"terminal": {
			"type": "object",
			"required": ["name"],
			"properties": {
				"name": {
					"type": "string",
					"description": "Display name for the terminal tab",
					"examples": ["Build", "Test", "Server"]
				},
				"shell": {
					"type": "string",
					"minLength": 1,
					"description": "Optional shell override for this terminal tab"
				},
				"command": {
					"type": "string",
					"minLength": 1,
					"description": "Optional command executed once when the terminal session starts"
				},
				"cwd": {
					"type": "string",
					"minLength": 1,
					"description": "Optional working directory relative to project.path"
				}
			},
			"additionalProperties": false
		},
		"terminalShellConfig": {
			"type": "object",
			"properties": {
				"command": {
					"type": "string",
					"description": "Shell executable to spawn"
				},
				"args": {
					"type": "array",
					"description": "Optional arguments passed to the shell executable",
					"items": {
						"type": "string"
					}
				},
				"env": {
					"type": "object",
					"description": "Optional environment variable overrides",
					"additionalProperties": {
						"type": "string"
					}
				}
			},
			"additionalProperties": false
		},
		"terminalSettings": {
			"type": "object",
			"properties": {
				"shell": {
					"type": "string",
					"minLength": 1,
					"description": "Default shell for terminals without explicit shell"
				},
				"shells": {
					"type": "object",
					"description": "Shell command definitions keyed by custom shell names",
					"propertyNames": {
						"type": "string",
						"minLength": 1
					},
					"additionalProperties": {
						"$ref": "#/$defs/terminalShellConfig"
					}
				}
			},
			"additionalProperties": false
		},
		"fontSettings": {
			"type": "object",
			"properties": {
				"family": {
					"type": "string",
					"minLength": 1,
					"description": "Font family applied to Monaco editors and xterm"
				},
				"size": {
					"type": "number",
					"exclusiveMinimum": 0,
					"description": "Font size applied to Monaco editors and xterm"
				}
			},
			"additionalProperties": false
		},
		"explorer": {
			"type": "object",
			"required": ["name", "path"],
			"properties": {
				"name": {
					"type": "string",
					"description": "Display name for the explorer tab",
					"examples": ["Frontend", "Backend"]
				},
				"path": {
					"type": "string",
					"description": "Path relative to project.path",
					"examples": ["src", "packages/app/src"]
				},
				"ignore": {
					"type": "array",
					"description": "Folder names to ignore recursively for this explorer",
					"items": {
						"type": "string"
					}
				}
			},
			"additionalProperties": false
		}
	}
}
